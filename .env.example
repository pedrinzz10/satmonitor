# ──────────────────────────────────────────────────────────────────
# SatMonitor — variáveis de ambiente
#
# Como usar:
#   cp .env.example .env
#   nano .env   # preencha os valores reais
#
# NUNCA faça commit do arquivo .env (está no .gitignore)
# ──────────────────────────────────────────────────────────────────

# Segredo JWT — string longa e aleatória (mínimo 32 caracteres)
JWT_SECRET=troque-por-string-longa-e-aleatoria-minimo-32-chars

# PostgreSQL — container satmonitor-db-RM562312
POSTGRES_USER=satuser
POSTGRES_PASSWORD=troque-por-senha-segura
